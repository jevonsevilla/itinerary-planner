  <!-- ===================================================== -->
  <!-- DAY 7 — Apr 23 (Thu) · Kobe + Group Split            -->
  <!-- ===================================================== -->
  <Folder>
    <name>Day 7 — Apr 23 (Thu) · Kobe + Group Split</name>
    <description>Kobe Chinatown + Kobe beef lunch (everyone), then Cathay Pacific group flies home while Cebu Pacific group has one final night at Craftroom. Budget: ¥18,000–30,000.</description>

    <Placemark>
      <name>Kobe Nankinmachi (Chinatown)</name>
      <styleUrl>#day7-pin</styleUrl>
      <description><![CDATA[
        <b>09:30–11:00 (Everyone)</b><br>
        Kobe's vibrant Chinatown — 100+ restaurants and stalls.<br><br>
        • Steamed buns (nikuman) — the street food staple<br>
        • Ramen, baozi, Cantonese roast meats<br>
        • Free to enter and explore<br><br>
        <b>Getting here:</b> Osaka Station → Sannomiya (JR Special Rapid, 20 min, ¥420), 10-min walk<br>
        <i>Cost: ¥500–1,000 street food</i>
      ]]></description>
      <Point><coordinates>135.1845,34.6882,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Kobe Beef Lunch — Tanryu or Mouriya</name>
      <styleUrl>#day7-pin</styleUrl>
      <description><![CDATA[
        <b>11:00–12:30 (Everyone — full group farewell meal)</b><br>
        ⭐ Authentic Kobe beef teppanyaki in Kobe itself.<br><br>
        • <b>Tanryu</b>: well-regarded teppanyaki near Sannomiya<br>
        • <b>Mouriya</b>: founded 1885, Kobe's oldest Kobe beef restaurant<br>
        • Lunch sets are 50–70% cheaper than dinner (¥3,000–6,000 vs ¥10,000+)<br><br>
        <i>This is the final shared meal before the Cathay group branches off</i><br>
        <i>Cost: ¥3,000–6,000 per person</i>
      ]]></description>
      <Point><coordinates>135.1845,34.6882,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Kobe Harborland &amp; Meriken Park (5J group)</name>
      <styleUrl>#day7-pin</styleUrl>
      <description><![CDATA[
        <b>12:30–14:00 (Cebu Pacific group only)</b><br>
        Kobe's waterfront — harbour views and iconic landmarks.<br><br>
        • Kobe Port Tower (red lattice tower)<br>
        • BE KOBE monument — the famous photo spot<br>
        • Kobe Maritime Museum<br><br>
        <i>After this: Transit back to Osaka for shopping and the final Cebu Pacific night</i><br>
        <i>Cost: Free (harbour walk)</i>
      ]]></description>
      <Point><coordinates>135.1862,34.6769,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>KIX — Cathay Pacific Departure (17:35)</name>
      <styleUrl>#day7-pin</styleUrl>
      <description><![CDATA[
        <b>Cathay Pacific group only — departs 17:35</b><br><br>
        <b>Timeline:</b><br>
        • 12:30 — Leave Kobe after lunch<br>
        • 13:00 — Collect luggage from hotel<br>
        • 14:00 — Nankai Rapi:t from Namba (¥1,520)<br>
        • 14:40 — Arrive KIX Terminal 2<br>
        • 17:35 — Depart CX → MNL (arrives 00:15+1)
      ]]></description>
      <Point><coordinates>135.2441,34.4320,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Craftroom — Cebu Final Night (#58 Asia's 50 Best Bars 2025)</name>
      <styleUrl>#day7-pin</styleUrl>
      <description><![CDATA[
        <b>20:30–22:30 (Cebu Pacific group, last night)</b><br><br>
        ⭐ Highest-ranked bar in Osaka — 6-seat precision counter under Osaka Ekimae Daiichi Building in Umeda.<br><br>
        • No written menu — bespoke cocktails<br>
        • 20-min metro from Namba for the definitive Osaka top-50 experience<br>
        • Aim to leave by 22:30 — flight tomorrow<br><br>
        <b>Alt:</b><br>
        • Bar Freedom (Sennichimae, walking distance from hotel) — 10-seat whisky bar ¥2,000–4,000<br>
        • Second visit to Bar Nayuta (Amemura) — ¥3,000–5,000<br><br>
        <b>Earlier — Quiet dinner in Namba 19:00:</b><br>
        • Kushikatsu Daruma — Osaka's most iconic bite ¥1,500–2,500<br>
        • <b>Jibundoki</b> (Bib Gourmand) — teppanyaki okonomiyaki/negiyaki/modanyaki ¥2,000–3,000<br>
        • Kiji (Bib Gourmand) — fluffy okonomiyaki ¥1,500–2,500<br>
        <i>Cost: ¥3,000–6,000 per person</i>
      ]]></description>
      <Point><coordinates>135.4971,34.7005,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Day 7 Route</name>
      <styleUrl>#day7-line</styleUrl>
      <LineString>
        <tessellate>1</tessellate>
        <coordinates>
