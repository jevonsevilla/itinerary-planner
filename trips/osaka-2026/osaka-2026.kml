  <!-- ===================================================== -->
  <!-- DAY 4 — Apr 20 (Mon) · Kyoto → Osaka → Yoshino       -->
  <!-- ===================================================== -->
  <Folder>
    <name>Day 4 — Apr 20 (Mon) · Kyoto → Osaka → Yoshino</name>
    <description>Morning transfer to Osaka, drop luggage, then Kintetsu to Mount Yoshino for 30,000 cherry trees at golden hour. Budget: ¥8,500–13,000.</description>

    <Placemark>
      <name>Kyoto Station → Osaka (JR Special Rapid)</name>
      <styleUrl>#day4-pin</styleUrl>
      <description><![CDATA[
        <b>09:30–10:00 transfer</b><br>
        Check out of Kyoto hotel, JR Kyoto Line Special Rapid to Osaka Station.<br><br>
        • 28 min, ¥580<br>
        • From Gion: taxi to Kyoto Station (~15 min, ¥1,500) or Keihan + JR Nara Line<br><br>
        <i>Then Metro Midosuji to Namba (¥240, 10 min)</i>
      ]]></description>
      <Point><coordinates>135.7588,34.9858,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Namba — Osaka Hotel Bag Drop</name>
      <styleUrl>#day4-pin</styleUrl>
      <description><![CDATA[
        <b>10:45–11:15</b><br>
        Drop luggage at Osaka hotel — request early check-in; front desk will hold bags otherwise.<br><br>
        • 4 nights in Osaka (Apr 20–23)<br>
        • Minami/Namba area puts you 10 min walk from everything<br><br>
        <i>Then 11:15–12:30: free Dotonbori stroll or rest, pack Yoshino snacks</i>
      ]]></description>
      <Point><coordinates>135.5011,34.6687,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Osaka-Abenobashi Station (Kintetsu)</name>
      <styleUrl>#day4-pin</styleUrl>
      <description><![CDATA[
        <b>13:10 — Kintetsu Limited Express to Yoshino</b><br><br>
        • 76 min, ¥1,480<br>
        • Reserved seats required — buy at station or online<br>
        • Kintetsu is NOT covered by JR Pass (private railway)<br>
        • Next LE if missed: 14:10 (cuts golden-hour buffer)<br><br>
        <i>15 min walk from Namba hotel or 1 stop on Tanimachi Line</i>
      ]]></description>
      <Point><coordinates>135.5136,34.6465,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Yoshino Station</name>
      <styleUrl>#day4-pin</styleUrl>
      <description><![CDATA[
        <b>14:26 — Arrive Yoshino</b><br>
        Starting point for the mountain hike.<br><br>
        • Ropeway up: ¥450 one-way (3 min, saves the steepest section)<br>
        • Ropeway is one-way up only — plan to walk the full descent<br><br>
        <i>Cost: ¥450 ropeway</i>
      ]]></description>
      <Point><coordinates>135.8574,34.3659,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Kinpusen-ji &amp; Naka-Senbon — Kakinoha-zushi Lunch</name>
      <styleUrl>#day4-pin</styleUrl>
      <description><![CDATA[
        <b>14:40–16:15 · Middle slopes</b><br>
        Kinpusen-ji is Japan's second-largest wooden structure after Todaiji's Great Hall.<br><br>
        • Kinpusen-ji optional ¥800<br>
        • <b>Lunch 15:15:</b> kakinoha-zushi (persimmon-leaf sushi) at Yadoroku or Hatsuse — ¥1,500–2,500, the Yoshino specialty<br>
        • Cherry blossom density increases with altitude<br><br>
        <b>Area sequence (bottom to top):</b><br>
        Shimo-Senbon → <b>Naka-Senbon</b> → Kami-Senbon → Oku-Senbon<br>
        <i>Cost: ¥1,500–2,500 lunch</i>
      ]]></description>
      <Point><coordinates>135.8594,34.3717,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Hanayagura Viewpoint (Kami-Senbon) — Golden Hour</name>
      <styleUrl>#day4-pin</styleUrl>
      <description><![CDATA[
        <b>17:15–18:50 · Upper slopes</b><br>
        ⭐⭐ THE visual highlight of the entire trip — the whole mountain turns amber-pink across 30,000 trees.<br><br>
        • Sunset ~18:50 on April 20<br>
        • Be in position by 17:45 — the light lasts a full hour<br>
        • By April 20, lower slopes finishing but Kami-Senbon at peak<br>
        • ~60 min hike up from Naka-Senbon<br><br>
        <i>Cost: Free viewpoint. Snack ¥500–800.</i>
      ]]></description>
      <Point><coordinates>135.8631,34.3762,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Oku-Senbon (contingency — latest blooms)</name>
      <styleUrl>#day4-pin</styleUrl>
      <description><![CDATA[
        <b>Alternative if Kami-Senbon past peak</b><br>
        ~30 min further on foot than Hanayagura; latest-blooming zone on the mountain.<br><br>
        • Check local bloom reports (吉野山桜情報) on the morning of your visit<br>
        • Trade-off: less time at Hanayagura, freshest blooms<br><br>
        <i>Cost: Free</i>
      ]]></description>
      <Point><coordinates>135.8672,34.3810,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Descent + Regular Express back to Osaka</name>
      <styleUrl>#day4-pin</styleUrl>
      <description><![CDATA[
        <b>18:50–21:20</b><br>
        Full descent on foot (~60 min) then regular express back to Abenobashi.<br><br>
        • Limited Express last runs ~16:04 — evening is regular express (~90 min, ¥1,170)<br>
        • Use phone torch for the last descent stretch after dark<br><br>
        <b>Late dinner back in Namba (21:45):</b> Ichiran ramen or izakaya, ¥1,000–2,000
      ]]></description>
      <Point><coordinates>135.5011,34.6687,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Day 4 Route</name>
      <styleUrl>#day4-line</styleUrl>
      <LineString>
        <tessellate>1</tessellate>
        <coordinates>
          135.7588,34.9858,0
          135.5011,34.6687,0
          135.5136,34.6465,0
          135.8574,34.3659,0
          135.8594,34.3717,0
          135.8631,34.3762,0
          135.8672,34.3810,0
          135.8574,34.3659,0
          135.5136,34.6465,0
          135.5011,34.6687,0
        </coordinates>
      </LineString>
    </Placemark>
  </Folder>

  <!-- ===================================================== -->
  <!-- DAY 5 — Apr 21 (Tue) · Classic Osaka                 -->
  <!-- ===================================================== -->
  <Folder>
    <name>Day 5 — Apr 21 (Tue) · Classic Osaka</name>
    <description>Osaka Castle, Kuromon, Shinsekai, Shinsaibashi shopping, Mizuno okonomiyaki, Ura Namba izakaya crawl, Bar Nayuta speakeasy. Budget: ¥13,000–21,000.</description>

    <Placemark>
      <name>Osaka Castle Park &amp; Tower</name>
      <styleUrl>#day5-pin</styleUrl>
      <description><![CDATA[
        <b>10:00–12:30</b><br>
        One of Japan's most famous castles.<br><br>
        • Entry: ¥1,200 (tower) — or free to walk the park<br>
        • Check yaezakura (late-blooming double cherry) near Tamatsukuri Gate (SW)<br>
        • Bloom mid-to-late April — perfect timing<br><br>
        <b>Getting here:</b> Namba → Temmabashi (Metro Sakaisuji Line, ¥230, 10 min)<br>
        <i>Cost: ¥1,200 or free</i>
      ]]></description>
      <Point><coordinates>135.5259,34.6873,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Kuromon Ichiba Market — Lunch</name>
      <styleUrl>#day5-pin</styleUrl>
      <description><![CDATA[
        <b>12:45–14:00</b><br>
        "Osaka's Kitchen" — 170+ stalls of fresh seafood and produce.<br><br>
        <b>Must-try:</b><br>
        • Grilled scallops<br>
        • Fresh sashimi<br>
        • Tamagoyaki (egg omelette)<br>
        • Wagyu beef skewers<br><br>
        <b>Getting here:</b> Osaka Castle → Nippombashi (Metro Tanimachi Line, ¥230)<br>
        <i>Cost: ¥2,000–3,000</i>
      ]]></description>
      <Point><coordinates>135.5085,34.6672,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Shinsekai &amp; Tsutenkaku Tower</name>
      <styleUrl>#day5-pin</styleUrl>
      <description><![CDATA[
        <b>14:15–15:30</b><br>
        Retro old Osaka neighbourhood with 1950s vibes.<br><br>
        • Tsutenkaku Tower — iconic retro landmark<br>
        • Kushikatsu Daruma — the original kushikatsu restaurant<br>
        • Billiken (god of things as they ought to be) statues<br><br>
        <b>Getting here:</b> Kuromon → Dobutsuen-mae (Metro Sakaisuji Line, ¥230)<br>
        <i>Cost: Free to explore</i>
      ]]></description>
      <Point><coordinates>135.5063,34.6515,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Namba Yasaka Shrine</name>
      <styleUrl>#day5-pin</styleUrl>
      <description><![CDATA[
        <b>15:30–16:00</b><br>
        Hidden gem — giant lion-head stage (butai) used for performances.<br><br>
        • One of Osaka's most unusual shrines<br>
        • Free entry; 5 min walk from Namba<br><br>
        <i>Cost: Free</i>
      ]]></description>
      <Point><coordinates>135.4968,34.6594,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Shinsaibashi Arcade + Don Quijote</name>
      <styleUrl>#day5-pin</styleUrl>
      <description><![CDATA[
        <b>16:00–18:00</b><br>
        Osaka's main covered shopping arcade (600m long) plus the iconic Don Quijote flagship.<br><br>
        • Department stores, brand outlets, tax-free for tourists<br>
        • Don Quijote for discounted everything<br><br>
        <i>Then: Rest at hotel 18:00–19:00 before dinner</i>
      ]]></description>
      <Point><coordinates>135.5005,34.6741,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Mizuno — Okonomiyaki Dinner (Bib Gourmand)</name>
      <styleUrl>#day5-pin</styleUrl>
      <description><![CDATA[
        <b>19:00–20:30</b><br>
        ⭐ Michelin <b>Bib Gourmand</b> (6 consecutive years). Famous okonomiyaki restaurant on Dotonbori — 100+ years old.<br><br>
        • Arrive 18:30 to queue before opening<br>
        • Famous yamaimoyaki (yam flour okonomiyaki)<br>
        • Cash only, basic decor, legendary flavour<br><br>
        <b>Alts (both Bib Gourmand):</b><br>
        • Kiji — fluffy okonomiyaki, shorter queue, serious local following. ¥1,500–2,500<br>
        • Ajinoya — Dotonbori institution, specialty is buttery scallop okonomiyaki. ¥1,800–3,000<br><br>
        <i>Cost: ¥1,650–2,500 per person</i>
      ]]></description>
      <Point><coordinates>135.5011,34.6687,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Ura Namba — Izakaya Crawl</name>
      <styleUrl>#day5-pin</styleUrl>
      <description><![CDATA[
        <b>20:30–22:30</b><br>
        Narrow alleys east of Namba Station — cold beer, skewers, shoulder-to-shoulder with locals.<br><br>
        • 3–4 small spots, 1–2 drinks each — kuidaore style<br>
        • Budget ¥700–1,500 per place<br><br>
        <b>Alt:</b> Tenma tachinomi (standing-bar street) 1 stop via JR Loop Line — drinks from ¥50–300<br>
        <i>Cost: ¥2,500–4,000</i>
      ]]></description>
      <Point><coordinates>135.5039,34.6665,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Bar Nayuta — Speakeasy (#100 Asia's 50 Best Bars 2025)</name>
      <styleUrl>#day5-pin</styleUrl>
      <description><![CDATA[
        <b>22:30–00:00</b><br>
        Hidden door near Triangle Park in Amemura: elevator → handwritten note → dark alley → tiny door.<br><br>
        • Bespoke cocktails, no written menu — tell the bartender your preferences<br>
        • House-made bitters and infusions<br>
        • 10–15 min walk from Ura Namba through Shinsaibashi<br><br>
        <i>Cost: ¥3,000–5,000 per person</i>
      ]]></description>
      <Point><coordinates>135.4989,34.6725,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Day 5 Route</name>
      <styleUrl>#day5-line</styleUrl>
      <LineString>
        <tessellate>1</tessellate>
        <coordinates>
          135.5011,34.6687,0
          135.5259,34.6873,0
          135.5085,34.6672,0
          135.5063,34.6515,0
          135.4968,34.6594,0
          135.5005,34.6741,0
          135.5011,34.6687,0
          135.5039,34.6665,0
          135.4989,34.6725,0
        </coordinates>
      </LineString>
    </Placemark>
  </Folder>

  <!-- ===================================================== -->
  <!-- DAY 6 — Apr 22 (Wed) · Aquarium + Nara + Lamp Bar    -->
  <!-- ===================================================== -->
  <Folder>
    <name>Day 6 — Apr 22 (Wed) · Aquarium + Nara + Lamp Bar</name>
    <description>Osaka Aquarium in the morning, JR to Nara for deer and Todaiji, evening at Lamp Bar (#46 Asia's 50 Best). Budget: ¥14,000–23,000.</description>

    <Placemark>
      <name>Osaka Aquarium Kaiyukan</name>
      <styleUrl>#day6-pin</styleUrl>
      <description><![CDATA[
        <b>10:15–12:45</b><br>
        One of the world's largest aquariums — centred on a massive whale shark tank.<br><br>
        • Entry: ¥2,700<br>
        • Whale shark and giant spider crab are highlights<br>
        • Pacific Ocean tank is 8 floors tall<br>
        • Allow 2–2.5 hrs<br><br>
        <b>Getting here:</b> Namba → Osakako (Metro Midosuji → Chuo Line, ¥230, 20 min)<br>
        <i>Cost: ¥2,700</i>
      ]]></description>
      <Point><coordinates>135.4284,34.6548,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Nara Park — Deer Feeding</name>
      <styleUrl>#day6-pin</styleUrl>
      <description><![CDATA[
        <b>14:25–15:30</b><br>
        Over 1,000 free-roaming deer considered sacred messengers of the gods.<br><br>
        • Entry: Free<br>
        • Deer crackers (shika senbei): ¥200<br>
        • Bow to deer first — they bow back!<br>
        • Keep bags zipped; deer eat paper and maps<br>
        • Late-blooming Naranoyaezakura possible mid-late April<br><br>
        <b>Getting here:</b> JR Namba → JR Nara (Yamatoji Rapid, 50 min, ¥570), then 15–20 min walk<br>
        <i>Cost: ¥200</i>
      ]]></description>
      <Point><coordinates>135.8401,34.6851,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Todaiji Temple — Great Buddha</name>
      <styleUrl>#day6-pin</styleUrl>
      <description><![CDATA[
        <b>15:30–16:30</b><br>
        Home to Japan's largest bronze Buddha (15m), housed in the world's largest wooden building.<br><br>
        • Entry: ¥600<br>
        • Daibutsu cast in 752 AD<br>
        • Try squeezing through the hole in the pillar for enlightenment<br>
        • Closes 17:30<br><br>
        <i>Cost: ¥600</i>
      ]]></description>
      <Point><coordinates>135.8398,34.6888,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Kasuga Taisha Shrine</name>
      <styleUrl>#day6-pin</styleUrl>
      <description><![CDATA[
        <b>17:00–17:30</b><br>
        UNESCO World Heritage shrine famous for thousands of stone and bronze lanterns.<br><br>
        • Inner area: ¥500 | Outer grounds: Free<br>
        • 3,000+ lanterns line the paths<br>
        • Founded 768 AD<br><br>
        <i>⏭️ Skippable: Isui-en Garden (¥900) or Yoshiki-en Garden (free for foreigners)</i><br>
        <i>Cost: ¥500</i>
      ]]></description>
      <Point><coordinates>135.8491,34.6815,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Lamp Bar — Nara (#46 Asia's 50 Best Bars 2025)</name>
      <styleUrl>#day6-pin</styleUrl>
      <description><![CDATA[
        <b>19:30–21:30</b><br>
        ⭐ World-class cocktail bar by Michito Kaneko (2015 World Class Bartending champion).<br><br>
        • Three antique-furnished rooms with different motifs<br>
        • No written menu — bartenders tailor drinks using local Nara ingredients<br>
        • 📌 <b>Reserve ahead — essential</b><br><br>
        <i>This is the full-group farewell evening — Kobe beef lunch tomorrow is the final shared meal before the split</i><br>
        <i>Cost: ¥4,000–8,000 per person</i>
      ]]></description>
      <Point><coordinates>135.8243,34.6794,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Day 6 Route (Osaka → Nara)</name>
      <styleUrl>#day6-line</styleUrl>
      <LineString>
        <tessellate>1</tessellate>
        <coordinates>
          135.5011,34.6687,0
          135.4284,34.6548,0
          135.5011,34.6687,0
          135.8401,34.6851,0
